{
  "name": "noc-tune",
  "version": "1.0.1",
  "description": "NOC Tune - Network Quality Testing Tool",
  "main": "main.js",
  "homepage": "https://github.com/basnugroho/noctune",
  "author": {
    "name": "Baskoro Nugroho",
    "email": "baskoro.nugroho@tif.co.id"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "id.solusee.noctune",
    "productName": "NOC Tune",
    "artifactName": "NOC-Tune-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../ui",
        "to": "ui"
      },
      {
        "from": "../notebooks",
        "to": "notebooks",
        "filter": ["config.txt"]
      }
    ],
    "mac": {
      "extraResources": [
        {
          "from": "../dist/noctune-backend",
          "to": "backend/noctune-backend"
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "extraResources": [
        {
          "from": "../dist/noctune-backend.exe",
          "to": "backend/noctune-backend.exe"
        }
      ],
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "extraResources": [
        {
          "from": "../dist/noctune-backend",
          "to": "backend/noctune-backend"
        }
      ],
      "icon": "resources/icon.png",
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "NOC Tune",
      "uninstallDisplayName": "NOC Tune",
      "createDesktopShortcut": true
    }
  }
}
